@article{Sadl15,
	address = {United Kingdom; Sadler-Smith, Eugene: Surrey Business School, University of Surrey, Guildford, United Kingdom, GU2 7XH, e.sadler-smith{\char64}surrey.ac.uk},
	author = {Sadler-Smith, Eugene},
	date-added = {2025-05-20 12:45:19 -0600},
